# Port configuration for the Express server during tests
PORT=3001

# PostgreSQL connection string for Prisma - targeting potens_audit_log_test
DATABASE_URL="postgresql://postgres:bhargav@localhost:5432/potens_audit_log_test?schema=public"

# Secret API Key required for authenticated X-API-Key requests
API_KEY="my-secret-api-key"

# Node environment flag (development, production, test)
NODE_ENV="test"
